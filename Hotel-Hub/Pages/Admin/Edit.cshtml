@page
@model Hotel_Hub.Pages.Admin.EditModel
@{
    ViewData["Title"] = "Editar Reservación";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
                
                <div class="bg-dark text-white p-4">
                    <h3 class="mb-0 fw-bold">
                        <i class="bi bi-pencil-square me-2"></i>Editar Reserva #@Model.Reservacion.Id
                    </h3>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                        <input type="hidden" asp-for="Reservacion.Id" />

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-dark">NOMBRE DEL HUÉSPED</label>
                            <input asp-for="Reservacion.NombreHuesped" class="form-control" />
                            <span asp-validation-for="Reservacion.NombreHuesped" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-dark">CORREO ELECTRÓNICO</label>
                            <input asp-for="Reservacion.CorreoUsuario" class="form-control" />
                            <span asp-validation-for="Reservacion.CorreoUsuario" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-dark">HABITACIÓN</label>
                                <select asp-for="Reservacion.HabitacionId" class="form-select" asp-items="Model.ListaHabitaciones">
                                    <option value="" disabled>-- Seleccione una habitación --</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">COSTO ACTUAL</label>
                                <div class="form-control bg-light fw-bold text-success">$@Model.Reservacion.CostoTotal</div>
                                <input type="hidden" asp-for="Reservacion.CostoTotal" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-dark">FECHA ENTRADA</label>
                                <input asp-for="Reservacion.FechaEntrada" class="form-control" type="date" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-dark">FECHA SALIDA</label>
                                <input asp-for="Reservacion.FechaSalida" class="form-control" type="date" />
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-dark w-100 py-2 shadow-sm" style="border-radius: 10px;">
                                Guardar Cambios
                            </button>
                            <a asp-page="./Index" class="btn btn-light border-secondary text-secondary w-100 py-2 shadow-sm"
                                   style="border-radius: 10px; background-color: white; transition: 0.3s;"
                                   onmouseover="this.style.backgroundColor='#e2e6ea'; this.style.color='black';"
                                   onmouseout="this.style.backgroundColor='white'; this.style.color='#6c757d';">
                                Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>