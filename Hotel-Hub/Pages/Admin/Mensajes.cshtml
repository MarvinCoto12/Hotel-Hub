@page
@model Hotel_Hub.Pages.Admin.MensajesModel
@{
    ViewData["Title"] = "Panel de Soporte";
}

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mx-4 mt-3 shadow-sm" role="alert">
        🚀 @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mx-4 mt-3 shadow-sm" role="alert">
        ❌ @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded-3 shadow-sm border border-secondary"
         style="background-color: rgba(33, 37, 41, 0.85); backdrop-filter: blur(4px);">
        <h2 class="fw-bold text-white mb-0" style="font-size: 1.65rem; letter-spacing: -0.5px;">
            📥 Bandeja de Servicio al Cliente
        </h2>
        <span class="badge bg-light text-dark fw-semibold p-2 fs-6 shadow-sm">Panel Administrativo</span>
    </div>

    <ul class="nav nav-tabs mb-3 border-bottom-0 gap-1">
        <li class="nav-item">
            <a class="nav-link @(Model.EstadoFiltro == "Pendiente" ? "active fw-bold border-bottom-0" : "bg-white bg-opacity-75 text-dark shadow-sm")"
               asp-route-estadoFiltro="Pendiente">⚠️ Pendientes</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.EstadoFiltro == "Respondido" ? "active fw-bold border-bottom-0" : "bg-white bg-opacity-75 text-dark shadow-sm")"
               asp-route-estadoFiltro="Respondido">✅ Respondidos</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.EstadoFiltro == "Archivado" ? "active fw-bold border-bottom-0" : "bg-white bg-opacity-75 text-dark shadow-sm")"
               asp-route-estadoFiltro="Archivado">📁 Archivados</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.EstadoFiltro == "Todos" ? "active fw-bold border-bottom-0" : "bg-white bg-opacity-75 text-dark shadow-sm")"
               asp-route-estadoFiltro="Todos">🌐 Todos</a>
        </li>
    </ul>

    <div class="card shadow-sm border-top-0" style="border-top-left-radius: 0;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Huésped / Correo</th>
                            <th>Asunto y Mensaje</th>
                            <th>Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ListaMensajes != null && Model.ListaMensajes.Any())
                        {
                            foreach (var item in Model.ListaMensajes)
                            {
                                string badgeColor = item.Estado switch
                                {
                                    "Pendiente" => "bg-warning text-dark",
                                    "Respondido" => "bg-success text-white",
                                    _ => "bg-secondary text-white"
                                };

                                <tr>
                                    <td class="small text-muted" style="width: 12%;">
                                        @item.FechaEnvio.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </td>

                                    <td style="width: 23%;">
                                        <div class="fw-bold text-dark">@item.Nombre</div>
                                        <small class="text-muted">@item.Correo</small>
                                        @if (item.ReservacionId != null)
                                        {
                                            <br />
                                            <span class="badge bg-info text-dark border mt-1 d-inline-block shadow-sm" style="font-size: 0.75rem;">
                                                🔗 Reserva: FE-2026-@item.ReservacionId
                                            </span>
                                        }
                                    </td>

                                    <td style="width: 40%; max-width: 0;">
                                        <div class="fw-bold text-dark text-truncate">@item.Asunto</div>
                                        <p class="text-secondary small mb-0 text-truncate">@item.Mensaje</p>
                                    </td>

                                    <td style="width: 10%;">
                                        <span class="badge @badgeColor">@item.Estado</span>
                                    </td>

                                    <td class="text-center" style="width: 15%;">
                                        <div class="d-inline-flex gap-1 align-items-center">
                                            @if (item.Estado == "Pendiente")
                                            {
                                                <button class="btn btn-sm btn-success"
                                                        type="button"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#collapseMensaje-@item.Id"
                                                        aria-expanded="false"
                                                        title="Ver y responder mensaje">
                                                    👁️‍🗨️ Responder
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-primary"
                                                        type="button"
                                                        data-bs-toggle="collapse"
                                                        data-bs-target="#collapseMensaje-@item.Id"
                                                        aria-expanded="false"
                                                        title="Ver detalles del mensaje">
                                                    👁️ Ver
                                                </button>
                                            }

                                            <form method="post" asp-page-handler="CambiarEstado" asp-route-id="@item.Id"
                                                  asp-route-estadoFiltro="@Model.EstadoFiltro" asp-route-paginaActual="@Model.PaginaActual" class="d-inline-flex gap-1 mb-0">
                                                @if (item.Estado != "Archivado")
                                                {
                                                    <button type="submit" name="nuevoEstado" value="Archivado" class="btn btn-sm btn-outline-secondary" title="Archivar Mensaje">📁</button>
                                                }
                                            </form>
                                        </div>
                                    </td>
                                </tr>

                                <tr class="border-0">
                                    <td colspan="5" class="p-0 border-0">
                                        <div class="collapse" id="collapseMensaje-@item.Id">
                                            <div class="p-4 bg-light border-start border-4 border-success text-dark">
                                                <div class="mb-2 d-flex flex-wrap align-items-center gap-2">
                                                    <span class="badge bg-dark">Asunto:</span>
                                                    <strong class="text-dark">@item.Asunto</strong>
                                                    @if (item.ReservacionId != null)
                                                    {
                                                        <span class="badge bg-info text-dark border shadow-sm">🔗 Vinculado a Reserva: FE-2026-@item.ReservacionId</span>
                                                    }
                                                </div>
                                                <div class="p-3 bg-white rounded shadow-sm border text-dark mb-3" style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.6;">@item.Mensaje</div>

                                                @if (item.Estado == "Pendiente")
                                                {
                                                    <div class="card border-0 shadow-sm rounded-3">
                                                        <div class="card-header bg-dark text-white fw-bold py-2">
                                                            ✍️ Redactar Respuesta al Huésped
                                                        </div>
                                                        <div class="card-body bg-white p-3">
                                                            <form method="post" asp-page-handler="EnviarRespuesta" asp-route-id="@item.Id"
                                                                  asp-route-estadoFiltro="@Model.EstadoFiltro" asp-route-paginaActual="@Model.PaginaActual">
                                                                <div class="mb-3">
                                                                    <textarea name="respuestaTexto" class="form-control" rows="4" placeholder="Escribe aquí la solución que se le enviará directamente al correo..." required></textarea>
                                                                </div>
                                                                <div class="text-end">
                                                                    <button type="submit" class="btn btn-primary fw-bold px-4 shadow-sm">
                                                                        📧 Enviar Correo de Respuesta
                                                                    </button>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                }
                                                else if (!string.IsNullOrEmpty(item.RespuestaAdmin))
                                                {
                                                    <div class="p-3 bg-secondary bg-opacity-10 rounded border mt-2 shadow-sm">
                                                        <p class="mb-1 text-muted small"><i class="bi bi-check-circle-fill text-success"></i> <strong>Respuesta enviada:</strong></p>
                                                        <p class="mb-0 text-dark" style="white-space: pre-wrap; font-style: italic; font-size: 0.95rem;">@item.RespuestaAdmin</p>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <div class="fs-4 mb-2">📭</div>
                                    No hay mensajes en la categoría <strong>@Model.EstadoFiltro</strong> actualmente.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (Model.TotalPaginas > 1)
    {
        <nav aria-label="Navegación de páginas de soporte" class="mt-4">
            <ul class="pagination justify-content-center shadow-sm">
                <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" asp-route-estadoFiltro="@Model.EstadoFiltro" asp-route-paginaActual="@(Model.PaginaActual - 1)">Anterior</a>
                </li>

                @for (int i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-route-estadoFiltro="@Model.EstadoFiltro" asp-route-paginaActual="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-route-estadoFiltro="@Model.EstadoFiltro" asp-route-paginaActual="@(Model.PaginaActual + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
</div>