@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hotel Hub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <img src="/images/fondo.webp" class="fondo" alt="fondo" />
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-page="/Index">🏨 Hotel Hub</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Reservaciones/Index">Reservaciones</a></li>
                        @if (Context.Session.GetString("IsAdmin") == "true")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold border border-warning rounded px-2 ms-lg-3" asp-page="/Admin/Index">⚙️ Admin</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3 mt-auto text-center">
        <div class="container">&copy; 2026 - Hotel Hub - <span class="fw-bold">UMOAR</span></div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>