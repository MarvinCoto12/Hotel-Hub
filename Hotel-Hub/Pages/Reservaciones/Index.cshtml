@page
@model Hotel_Hub.Pages.Reservaciones.IndexModel
@{
    ViewData["Title"] = "Reservas Activas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="welcome-card rounded fw-bold mb-0"
            style="background-color: rgba(255, 255, 255, 0.7);
            padding: 5px 15px;
            color: #2c3e50;
            display: inline-block;
            line-height: 1.2;">
            Reservas Activas
        </h2>

        <div class="d-flex align-items-center gap-2">
            <!-- Botón para mostrar/ocultar historial de reservas cerradas -->
            <button class="btn btn-outline-secondary shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#historialCollapse" aria-expanded="false" aria-controls="historialCollapse">
                Historial de Reservas Cerradas
            </button>

            <a asp-page="Create" class="btn btn-primary shadow-sm">
                + Nueva Reservación
            </a>
        </div>
    </div>

    <!-- Sección colapsable para historial de reservas cerradas -->
    <div class="collapse mb-4" id="historialCollapse">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Historial de Reservas Cerradas</h5>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Huésped</th>
                                <th>Estadía</th>
                                <th>Habitación</th>
                                <th>Tipo</th>
                                <th>Costo Total</th>
                                <th class="text-center">Factura</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.HistorialReservaciones.Any())
                            {
                                foreach (var h in Model.HistorialReservaciones)
                                {
                                    <tr>
                                        <td class="align-middle">
                                            @h.NombreHuesped <br />
                                            <small class="text-muted">@h.CorreoUsuario</small>
                                        </td>
                                        <td class="align-middle">
                                            <small class="text-muted d-block">Entrada: @h.FechaEntrada?.ToShortDateString()</small>
                                            <small class="text-muted d-block">Salida: @h.FechaSalida?.ToShortDateString()</small>
                                        </td>
                                        <td class="align-middle fw-bold">#@(h.Habitacion?.Numero ?? "N/A")</td>
                                        <td class="align-middle"><span class="badge bg-info text-dark">@(h.Habitacion?.Tipo ?? "N/A")</span></td>
                                        <td class="align-middle text-success fw-bold">$@h.CostoTotal.ToString("0.00")</td>
                                        <td class="align-middle text-center">
                                            <a asp-page-handler="DescargarFactura" asp-route-id="@h.Id" class="btn btn-sm btn-danger">📥 Descargar PDF</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-3">No hay reservas cerradas para mostrar.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form method="get" class="d-flex align-items-center gap-3">
                <label for="CorreoFiltro" class="fw-bold mb-0">Buscar mis reservas:</label>
                <input type="email" asp-for="CorreoFiltro" class="form-control w-50" maxlength="50" placeholder="Ingrese el correo con el que reservó..." required />
                <button type="submit" class="btn btn-dark px-4">Buscar</button>
                @if (!string.IsNullOrEmpty(Model.CorreoFiltro))
                {
                    <a asp-page="./Index" class="btn btn-outline-secondary">Limpiar</a>
                }
            </form>
        </div>
    </div>

    <!-- Botón de filtro rápido para ver solo huéspedes con estado CheckIn -->
    <div class="d-flex justify-content-end mb-3">
        @if (Model.FiltrarCheckIn)
        {
            <a asp-page="./Index" asp-route-CorreoFiltro="@Model.CorreoFiltro" class="btn btn-sm btn-outline-primary">Mostrar todos</a>
        }
        else
        {
            <a asp-page="./Index" asp-route-FiltrarCheckIn="true" asp-route-CorreoFiltro="@Model.CorreoFiltro" class="btn btn-sm btn-success">Ver huéspedes en hotel (Check-In)</a>
        }
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Huésped</th>
                        <th>Estadía</th>
                        <th>Habitación</th>
                        <th>Tipo</th>
                        <th>Costo Total</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaReservaciones.Any())
                    {
                        foreach (var item in Model.ListaReservaciones)
                        {
                            <tr>
                                <td class="align-middle fw-semibold">
                                    @item.NombreHuesped <br />
                                    <small class="text-muted fw-normal">@item.CorreoUsuario</small>
                                </td>
                                <td class="align-middle">
                                    <small class="text-muted d-block">Entrada: @item.FechaEntrada?.ToShortDateString()</small>
                                    <small class="text-muted d-block">Salida: @item.FechaSalida?.ToShortDateString()</small>
                                </td>
                                <td class="align-middle fw-bold">
                                    #@(item.Habitacion?.Numero ?? "N/A")
                                </td>
                                <td class="align-middle">
                                    <span class="badge bg-info text-dark">@(item.Habitacion?.Tipo ?? "N/A")</span>
                                </td>
                                <td class="align-middle text-success fw-bold">
                                    $@item.CostoTotal.ToString("0.00")
                                </td>
                                <td class="align-middle text-center">
                                    @if (item.Estado == "Activa")
                                    {
                                        <form method="post" asp-page-handler="MarcarCheckIn" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success shadow-sm">🔑 Check-In</button>
                                        </form>
                                    }
                                    else if (item.Estado == "CheckIn")
                                    {
                                        <form method="post" asp-page-handler="MarcarCheckOut" asp-route-id="@item.Id" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-warning shadow-sm">🚪 Check-Out</button>
                                        </form>
                                    }
                                    else if (item.Estado == "CheckOut")
                                    {
                                        <!-- Mostrar PDF solo si el estado es exactamente CheckOut -->
                                        <a asp-page-handler="DescargarFactura" asp-route-id="@item.Id" class="btn btn-sm btn-danger shadow-sm">📥 Descargar PDF</a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Estado</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else if (!string.IsNullOrEmpty(Model.CorreoFiltro))
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-danger">
                                No se encontraron reservaciones activas para el correo: <b>@Model.CorreoFiltro</b>
                            </td>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="fs-4 mb-2">🔍</i><br>
                                Ingrese su correo arriba para ver sus reservaciones protegidas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>