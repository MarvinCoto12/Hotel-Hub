@page
@model Hotel_Hub.Pages.Reservaciones.IndexModel
@{
    ViewData["Title"] = "Listado de Reservaciones";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Gestión de Reservaciones</h2>
        <a asp-page="Create" class="btn btn-primary shadow-sm">
            + Nueva Reservación
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nombre del Huésped</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Habitación</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ListaReservaciones.Any())
                    {
                        foreach (var item in Model.ListaReservaciones)
                        {
                            <tr>
                                <td class="align-middle fw-semibold">@item.NombreHuesped</td>
                                <td class="align-middle">@item.FechaEntrada.ToShortDateString()</td>
                                <td class="align-middle">@item.FechaSalida.ToShortDateString()</td>
                                <td class="align-middle">
                                    <span class="badge bg-info text-dark rounded-pill px-3">@item.NumeroHabitacion</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fs-4 mb-2">🏨</i><br>
                                No hay reservaciones registradas todavía.<br>
                                ¡Haz clic en "Nueva Reservación" para empezar!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>