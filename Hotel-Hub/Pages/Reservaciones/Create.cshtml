@page
@model Hotel_Hub.Pages.Reservaciones.CreateModel
@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">Formulario de Registro</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Reservacion.NombreHuesped" class="form-label fw-bold"></label>
                                <input asp-for="Reservacion.NombreHuesped" class="form-control" placeholder="Ej. Carlos Torres" />
                                <span asp-validation-for="Reservacion.NombreHuesped" class="text-danger small fw-bold"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Reservacion.CorreoUsuario" class="form-label fw-bold"></label>
                                <input asp-for="Reservacion.CorreoUsuario" class="form-control" placeholder="usuario@gmail.com" />
                                <span asp-validation-for="Reservacion.CorreoUsuario" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Reservacion.FechaEntrada" class="form-label fw-bold"></label>
                                <input asp-for="Reservacion.FechaEntrada" class="form-control" type="date" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="Reservacion.FechaEntrada" class="text-danger small fw-bold"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Reservacion.FechaSalida" class="form-label fw-bold"></label>
                                <input asp-for="Reservacion.FechaSalida" class="form-control" type="date" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="Reservacion.FechaSalida" class="text-danger small fw-bold"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Reservacion.HabitacionId" class="form-label fw-bold"></label>
                            <select asp-for="Reservacion.HabitacionId" asp-items="Model.OpcionesHabitaciones" class="form-select">
                                <option value="" disabled selected hidden>-- Seleccione una habitación --</option>
                            </select>
                            <span asp-validation-for="Reservacion.HabitacionId" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">Confirmar Reservación</button>
                            <a asp-page="Index" class="btn btn-dark shadow-sm">Volver</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>